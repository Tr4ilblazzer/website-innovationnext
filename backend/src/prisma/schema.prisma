generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  phone     String?
  subject   String
  message   String
  interest  String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_submissions")
}

model NewsletterSubscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String?
  active         Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("newsletter_subscribers")
}

model Vacancy {
  id           String           @id @default(uuid())
  title        String
  department   String
  location     String
  type         String
  level        String
  description  String
  requirements String[]
  niceToHave   String[]
  salary       String?
  closingDate  DateTime?
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]

  @@map("vacancies")
}

model JobApplication {
  id           String   @id @default(uuid())
  vacancyId    String
  firstName    String
  lastName     String
  email        String
  phone        String
  currentRole  String?
  experience   String
  coverLetter  String?
  cvUrl        String
  portfolioUrl String?
  linkedinUrl  String?
  status       String   @default("new")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  vacancy      Vacancy  @relation(fields: [vacancyId], references: [id])

  @@map("job_applications")
}

model BlogPost {
  id            String    @id @default(uuid())
  title         String
  slug          String    @unique
  excerpt       String
  content       String
  category      String
  tags          String[]
  authorName    String
  authorRole    String?
  featuredImage String?
  published     Boolean   @default(false)
  featured      Boolean   @default(false)
  readTime      Int       @default(5)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("blog_posts")
}

model CaseStudy {
  id            String    @id @default(uuid())
  title         String
  slug          String    @unique
  client        String
  industry      String
  domain        String
  challenge     String
  solution      String
  results       Json
  technologies  String[]
  duration      String?
  featuredImage String?
  published     Boolean   @default(false)
  featured      Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("case_studies")
}
